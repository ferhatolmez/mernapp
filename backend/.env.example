# MERN App — Ortam Değişkenleri

# ─── Sunucu ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# ─── MongoDB Atlas ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Frontend URL ────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Cloudinary (Kalıcı Depolama) ─────────────────────────────────
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Nodemailer) ─────────────────────────────────────────
# Development'ta otomatik Ethereal kullanılır.
# Production için SMTP bilgilerinizi girin:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ─── Redis (Opsiyonel) ──────────────────────────────────────────
# Redis yoksa uygulama cache olmadan çalışır.
REDIS_URL=redis://localhost:6379

# ─── Resend (Production Email) ──────────────────────────────────
# Render gibi SMTP portlarını engelleyen platformlarda HTTP tabanlı email API kullanılır.
# https://resend.com adresinden ücretsiz hesap açıp API key alabilirsiniz.
RESEND_API_KEY=re_your_api_key_here
